<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-5">
    <h1 style="font-weight: 700;">My Favorites</h1>
    <%= link_to "Find more plants", new_chat_path, class: "btn btn-outline-success rounded-pill px-4" %>
  </div>

  <div class="row row-cols-1 row-cols-md-3 g-4">
    <% if @favorites.any? %>
      <% @favorites.each do |favorite| %>
        <div class="col">
          <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
            <% if favorite.plant.image_url.present? %>
              <img src="<%= favorite.plant.image_url %>" class="card-img-top" style="height: 220px; object-fit: cover;" alt="<%= favorite.plant.name %>">
            <% else %>
              <div class="bg-secondary d-flex align-items-center justify-content-center" style="height: 220px;">
                <span class="text-white">No Image</span>
              </div>
            <% end %>

            <div class="card-body p-4">
              <h5 class="card-title mb-3" style="font-weight: 600;"><%= favorite.plant.name %></h5>

              <div class="d-flex flex-wrap gap-2 mb-4">
                <span class="badge rounded-pill border text-dark px-3 py-2" style="background: transparent; border-color: #ddd !important;">
                  ☀️ <%= favorite.plant.light_needs %>
                </span>
                <span class="badge rounded-pill border text-dark px-3 py-2" style="background: transparent; border-color: #ddd !important;">
                  💧 <%= favorite.plant.water_needs %>
                </span>
              </div>

              <div class="d-flex justify-content-between align-items-center mt-auto">
                <%= link_to "View Details", plant_path(favorite.plant), class: "btn btn-sm btn-success rounded-pill px-3 py-2" %>

                <%= link_to favorite_path(favorite),
                            data: { turbo_method: :delete, turbo_confirm: "Remove from garden?" },
                            class: "text-danger text-decoration-none p-2" do %>
                  <i class="fa-solid fa-trash-can"></i> 🗑️
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="col-12 text-center py-5">
        <p class="text-muted fs-4">Your garden is still empty...</p>
        <%= link_to "Explore our Plant Matchmaker", plants_path, class: "btn btn-success btn-lg rounded-pill mt-3" %>
      </div>
    <% end %>
  </div>
</div>
