<div class="container py-3">

  <div class="row align-items-center mb-4 justify-content-center mb-2">
    <div class="col-md-6 text-start pe-5">
      <p class="text-uppercase fw-semibold small mb-3" style="color: #7A9060; letter-spacing: 0.1em;">Your personal plant matchmaker</p>
      <h1 class="display-6 fw-semibold mb-3" style="font-family: Georgia, serif;">
        Find your <em style="color: #4A7C2F;">perfect</em> plant match
      </h1>
      <p class="lead text-muted mb-4">Answer a few questions about your space and lifestyle. We'll find the plant that's perfectly suited for you.</p>
      <div>
        <%= link_to "Get started", new_user_registration_path, class: "btn btn-success rounded-pill px-5 py-3" %>
      </div>
    </div>
    <div class="col-md-6">
  <%= image_tag "hero-plant.jpg", class: "img-fluid rounded-3", style: "max-height: 500px; width: 100%; object-fit: cover; object-position: top; margin-top: -40px;" %>
    </div>
  </div>

  <div class="row g-3 align-items-stretch text-center">
    <div class="col-md-4">
      <div class="border p-4 h-100 rounded-3" style="background: #F9FBF7;">
        <p style="font-size: 28px; color: #C8D9B8; font-family: Georgia, serif;">01</p>
        <h5 class="fw-semibold">Tell us about your space</h5>
        <p class="text-muted small">Light levels, pets, kids — we ask the things that matter</p>
        <%= image_tag "plant1.jpg", class: "img-fluid mt-3", style: "max-height: 120px;" %>
      </div>
    </div>
    <div class="col-md-4">
      <div class="border p-4 h-100 rounded-3" style="background: #F9FBF7;">
        <p style="font-size: 28px; color: #C8D9B8; font-family: Georgia, serif;">02</p>
        <h5 class="fw-semibold">We find your match</h5>
        <p class="text-muted small">Our AI filters plants to find the ones built for your life</p>
        <%= image_tag "plant2.jpg", class: "img-fluid mt-3", style: "max-height: 120px;" %>
      </div>
    </div>
    <div class="col-md-4">
      <div class="border p-4 h-100 rounded-3" style="background: #F9FBF7;">
        <p style="font-size: 28px; color: #C8D9B8; font-family: Georgia, serif;">03</p>
        <h5 class="fw-semibold">Meet your match</h5>
        <p class="text-muted small">Get your personalised plant recommendation and find where to buy it</p>
        <%= image_tag "plant3.jpg", class: "img-fluid mt-3", style: "max-height: 120px;" %>
      </div>
    </div>
  </div>

  <div class="mt-5 text-center mb-4">
    <p class="text-muted small mb-3">We match for</p>
    <div class="d-flex flex-wrap justify-content-center gap-2">
      <span class="badge rounded-pill border text-dark fs-6 fw-light">Non-toxic to pets</span>
      <span class="badge rounded-pill border text-dark fs-6 fw-light">Low light</span>
      <span class="badge rounded-pill border text-dark fs-6 fw-light">Low maintenance</span>
      <span class="badge rounded-pill border text-dark fs-6 fw-light">Air purifying</span>
      <span class="badge rounded-pill border text-dark fs-6 fw-light">Child safe</span>
      <span class="badge rounded-pill border text-dark fs-6 fw-light">Budget friendly</span>
    </div>
  </div>

</div>
